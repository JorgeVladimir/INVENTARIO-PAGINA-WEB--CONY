    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "jspdf": "^4.2.0",
    "jspdf-autotable": "^5.0.7",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.13.0",
    "recharts": "^3.7.0",
    "stripe": "^20.3.1",
    "tailwind-merge": "^3.5.0",
